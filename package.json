{
  "name": "stylediff",
  "version": "0.1.0",
  "description": "Responsive visual & style diff for web page sections — CLI + MCP",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "stylediff": "dist/bin/stylediff.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start:mcp": "tsx src/mcp/server.ts",
    "start:cli": "tsx src/bin/stylediff.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stylediff",
    "css",
    "style-diff",
    "visual-regression",
    "responsive",
    "breakpoints",
    "comparison",
    "mcp",
    "cli",
    "web"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "ora": "^8.1.0",
    "pixelmatch": "^6.0.0",
    "playwright": "^1.49.0",
    "pngjs": "^7.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
